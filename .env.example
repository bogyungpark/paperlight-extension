# Paperlight environment example
# Copy to .env.local for local dev. Real keys live in chrome.storage.local at runtime — these are dev defaults only.

VITE_DEFAULT_PROVIDER=openai
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_GEMINI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
VITE_GEMINI_MODEL=gemini-1.5-flash
